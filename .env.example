# ── Active provider (PROVIDER = "veo" in lib/config.ts) ──────────────
# Create a key at https://aistudio.google.com/apikey (free, ~1 minute)
GEMINI_API_KEY=

# Optional shared password. If set, the UI asks for it once and every
# API route requires it. Leave empty to run the app open.
APP_PASSWORD=

# ── Keys for the stub adapters (only needed after you implement them) ─
# OPENAI_API_KEY=      # Sora   — https://platform.openai.com/api-keys
# XAI_API_KEY=         # Grok   — https://console.x.ai/
# ARK_API_KEY=         # Seedance — https://console.byteplus.com/
